{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=user_tasks_db;Username=postgres;Password=postgres;Pooling=true;MinPoolSize=1;MaxPoolSize=100;CommandTimeout=10"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092", 
    "DefaultTopic": "user-task"
  },
  "OutboxProcessor": {
    "PollIntervalSeconds": 5,
    "BatchSize": 100,
    "MaxRetryCount": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "UserTaskManagement.DrivenAdapters.MessageBroker": "Debug",
      "UserTaskManagement.Infrastructure.BackgroundServices": "Debug"
    }
  },
  "AllowedHosts": "*"
}
